{
  "name": "b2b-saas-starter",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare-first B2B SaaS starter monorepo with TanStack Start, Effect v4, Drizzle D1, Better Auth, and Alchemy.",
  "homepage": "https://github.com/brandhaug/b2b-saas-starter#readme",
  "bugs": {
    "url": "https://github.com/brandhaug/b2b-saas-starter/issues"
  },
  "license": "MIT",
  "author": "Martin Brandhaug <martin@brandhaug.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandhaug/b2b-saas-starter.git"
  },
  "workspaces": [
    "apps/*",
    "infra",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "bun --cwd apps/web dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "bun --cwd apps/web test:e2e",
    "lint": "oxlint --type-aware --ignore-pattern '.context/**'",
    "lint:fix": "oxlint --type-aware --ignore-pattern '.context/**' --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "check:fix": "bun run lint:fix && bun run format",
    "db:generate": "bun --cwd packages/db db:generate",
    "db:migrate:local": "bun --cwd packages/db db:migrate:local",
    "db:migrate:remote": "bun --cwd packages/db db:migrate:remote",
    "db:seed": "bun scripts/seed.ts",
    "deploy": "bun alchemy.run.ts",
    "destroy": "bun alchemy.run.ts --destroy",
    "catalog:refresh": "bun --cwd apps/background catalog:refresh",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@b2b-saas-starter/capabilities": "workspace:*",
    "@b2b-saas-starter/db": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/language-service": "catalog:",
    "@playwright/test": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "alchemy": "catalog:",
    "bun-types": "catalog:",
    "drizzle-kit": "catalog:",
    "effect": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "shadcn": "catalog:",
    "storybook": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.3"
  },
  "packageManager": "bun@1.3.3",
  "catalog": {
    "@base-ui/react": "1.4.1",
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "4.20260516.1",
    "@effect/atom-react": "4.0.0-beta.93",
    "@effect/language-service": "0.86.1",
    "@effect/platform-bun": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.93",
    "@effect/sql-d1": "4.0.0-beta.93",
    "@effect/vitest": "4.0.0-beta.93",
    "@fontsource-variable/archivo": "5.2.8",
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/geist-mono": "5.2.7",
    "@mdx-js/rollup": "3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/test": "1.60.0",
    "@react-email/components": "1.0.12",
    "@react-email/preview-server": "5.2.10",
    "@react-email/render": "2.0.8",
    "@sentry/cloudflare": "10.53.1",
