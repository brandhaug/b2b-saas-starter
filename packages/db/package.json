{
  "name": "@b2b-saas-starter/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./service": "./src/service.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply b2b-saas-starter --local",
    "db:migrate:remote": "wrangler d1 migrations apply b2b-saas-starter --remote"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@b2b-saas-starter/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
