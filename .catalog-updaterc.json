{
  "$schema": "https://raw.githubusercontent.com/brandhaug/catalog-update-action/v1/schema.json",
  "defaultBranch": "master",
  "maxOpenPrs": 20,
  "concurrency": 10,
  "packageManager": "bun",
  "groups": [
    { "name": "react", "patterns": ["react", "react-dom"] },
    {
      "name": "tanstack-router",
      "patterns": [
        "@tanstack/react-router*",
        "@tanstack/router*",
        "@tanstack/react-start"
      ]
    },
    { "name": "tanstack", "patterns": ["@tanstack/*"] },
    { "name": "effect", "patterns": ["effect", "@effect/*"] },
    {
      "name": "tailwind",
      "patterns": ["tailwindcss", "@tailwindcss/*", "tailwind-merge", "tw-animate-css"]
    },
    { "name": "vite", "patterns": ["vite", "@vitejs/*"] },
    { "name": "oxc", "patterns": ["oxlint*", "oxfmt"] },
    { "name": "testing-library", "patterns": ["@testing-library/*"] },
    { "name": "zod", "patterns": ["zod"] },
    {
      "name": "mdx",
      "patterns": ["@mdx-js/*", "remark-*", "rehype-*", "@types/mdx"]
    },
    { "name": "all-patch-updates", "patterns": ["*"], "updateTypes": ["patch"] }
  ],
  "ignore": []
}
